# ---- Date Spot Planner — environment variables ----
# Copy this file to ".env" and fill in REAL values. NEVER commit ".env".
# See SETUP.md for where each value comes from.

# Google service account (from the downloaded JSON key)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# The service account's private key.
# Paste it as ONE line with literal "\n" escapes (NOT real line breaks), wrapped in quotes.
# It must match the "\\n" -> newline replacement done in src/lib/sheets.ts.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQID...REPLACE_ME...==\n-----END PRIVATE KEY-----\n"

# The ID of your EXISTING Google Sheet (the long string in its URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit )
GOOGLE_SHEET_ID=replace_with_your_sheet_id

# ---- Google sign-in (OAuth 2.0) ----
# From Google Cloud Console > APIs & Services > Credentials > OAuth client ID
# (type: Web application). See SETUP.md.
# NOTE: the same OAuth client is now also used to send date invites via the Gmail
# API. No extra env var is needed (each user's send token is stored in the `users`
# sheet), but you MUST enable the Gmail API and add the gmail.send scope to the
# consent screen — see SETUP.md Part A step 4 and Part C2.
GOOGLE_OAUTH_CLIENT_ID=replace_with_oauth_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=replace_with_oauth_client_secret

# Secret used to sign the login session cookie (NOT a Google value).
# Generate one with:  openssl rand -base64 32
SESSION_SECRET=replace_with_a_long_random_secret

# Absolute base URL of the app, used to build the OAuth redirect URI so it
# matches what's registered in the OAuth client. Optional in local dev (falls
# back to the request origin); SET THIS in production, e.g. https://your-app.vercel.app
APP_BASE_URL=http://localhost:3000

# (The iCal feed no longer uses a shared token. Each signed-in user's feed URL
#  carries their own base64-encoded email; the route authorizes it against the
#  active users registry. Nothing to configure here.)

# Central Google account whose Drive stores ALL file attachments (spots, plans,
# milestones). Every upload — no matter who uploads — lands in THIS account's
# Drive and counts against its 15 GB quota, kept private (never shared). This
# account MUST sign in to the app at least once and grant the drive.file scope
# so its token is stored in the `users` sheet; otherwise uploads fail with
# "owner_no_drive_grant". Requires the Drive API enabled + drive.file scope on
# the consent screen (see SETUP.md Part A). Uploads are capped at 4 MB each.
ATTACHMENTS_OWNER_EMAIL=you@gmail.com

# Timezone for all timestamps (Bangkok is fixed UTC+7, no DST).
APP_TIMEZONE=Asia/Bangkok

# Secret protecting the timeline reminder cron route (/api/cron/reminders).
# Generate one with:  openssl rand -base64 32
# On Vercel, set this and the daily cron in vercel.json calls the route with it
# automatically (Authorization: Bearer <CRON_SECRET>). Without it the route 500s.
CRON_SECRET=replace_with_a_long_random_secret
